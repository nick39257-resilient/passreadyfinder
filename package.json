{
  "name": "passreadyfinder",
  "version": "1.0.0",
  "description": "PassReady outbound lead finder — Phase A",
  "type": "module",
  "scripts": {
    "find": "tsx src/cli/find-leads.ts find",
    "list": "tsx src/cli/find-leads.ts list",
    "draft": "tsx src/cli/draft.ts",
    "auto-draft": "tsx src/cli/auto-draft.ts",
    "prestart": "node scripts/ensure-dashboard.mjs",
    "start": "tsx src/server/app.ts",
    "review": "tsx src/server/app.ts",
    "send": "tsx src/cli/send.ts",
    "enrich": "npx tsx src/engine/enricher.ts",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && npm run dashboard:build",
    "dashboard:install": "npm install --prefix dashboard --include=dev",
    "dashboard:dev": "npm run dev --prefix dashboard",
    "dashboard:build": "npm run build --prefix dashboard"
  },
  "keywords": [
    "passready",
    "fsa",
    "leads"
  ],
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@libsql/client": "^0.17.3",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "openai": "^6.39.0",
    "resend": "^6.12.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@vercel/node": "^5.8.4",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
