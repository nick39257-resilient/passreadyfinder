# Turso database (required on Render)
# Create a free database at https://turso.tech
TURSO_DATABASE_URL=libsql://your-database-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# Optional: use a local SQLite file instead of remote Turso (local dev only — not used on Render/Vercel)
# TURSO_LOCAL_PATH=./data/leads.db

# --- Texas module (isolated from UK FSA) ---
# TEXAS_AUSTIN_INSPECTIONS_URL=https://data.austintexas.gov/resource/ecmv-9xxi.json
# TEXAS_SCORE_URL=https://score.passready.us
# TEXAS_SITE_URL=https://passready.us
# TEXAS_OUTREACH_EMAIL_SUBJECT=HB 2844 mobile compliance — PassReady
# TEXAS_CONTACT_FORM_AUTO_SUBMIT=false
# TEXAS_APOLLO_DELAY_MS=1200
# TEXAS_APOLLO_BATCH_LIMIT=500
# TEXAS_AUTOPILOT_LIMIT=500
# TEXAS_AUTOPILOT_DELAY_MS=1500

# Optional: local dev port (Render sets PORT automatically)
# REVIEW_PORT=3000
# REVIEW_HOST=localhost

# --- Drafter (Phase B) — LLM + WhatsApp trapdoor link ---
# Gemini OpenAI compatibility layer:
OPENAI_API_KEY=your-google-api-key-here
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# Drafting model only (QueueDrafter, quick_draft, npm run draft). See ai.google.dev/gemini-api/docs/models
# GEMINI_DRAFT_MODEL=gemini-3.1-flash-lite

# Draft review gating:
# - If true, every draft routes to Needs Eyes (/review) instead of auto-postboxing.
REVIEW_ALL_DRAFTS=false

# WhatsApp Business number (digits only, no +)
WHATSAPP_NUMBER=447000000000

# SafeScore landing link (follow-up emails, WhatsApp prefill) — upsells to PassReady trial on-page
TRIAL_URL=https://score.passready.uk
# SCORE_URL=https://score.passready.uk
# First email includes SafeScore link only (default on). Set false to go reply-first again.
# OUTREACH_FIRST_TOUCH_LINK=false

# --- Sender (Phase D) — Namecheap Private Email SMTP ---
EMAIL_USER=nick@passready.us
EMAIL_PASS=your_mailbox_password
EMAIL_HOST=mail.privateemail.com
EMAIL_PORT=465
# Legacy aliases still supported: MAIL_USERNAME, MAIL_PASSWORD
# Softer subject — old default "upcoming fsa inspection" scared people off
# OUTREACH_EMAIL_SUBJECT=Quick question about your kitchen records
# Local testing only — never used in production unless ALLOW_TEST_EMAIL_FALLBACK=true
# TEST_EMAIL_ADDRESS=you@example.com
# ALLOW_TEST_EMAIL_FALLBACK=true

# --- Outreach limits & public links ---
# Max approved emails sent per UTC day (default 50 in product.config if unset)
# DAILY_SEND_CAP=30
# Public base URL for unsubscribe links in emails (required on Render for opt-out)
# PUBLIC_APP_URL=https://passreadyfinder.onrender.com

# --- Control panel security (recommended on Render) ---
# When set, job triggers require Authorization: Bearer <secret> header
# CONTROL_PANEL_SECRET=your-long-random-string

# SafeScore traffic pixel (embed on score.passready.uk / score.passready.us):
# <img src="https://readyfinder.onrender.com/api/score-traffic/pixel.gif?site=uk&key=YOUR_KEY" alt="" width="1" height="1" />
# SCORE_TRAFFIC_SECRET=your-traffic-beacon-key

# --- Phase 1 enrichment (Apollo + optional Playwright contact forms) ---
# APOLLO_API_KEY=your_apollo_api_key
# APOLLO_DAILY_CAP=0
# APOLLO_SUCCESSFUL_FIND_CAP=80
# CONTACT_FORM_MESSAGE=Hi — built PassReady for our kitchen. Free score: https://score.passready.uk
# CONTACT_FORM_FROM_EMAIL=nick@passready.uk
# CONTACT_FORM_AUTO_SUBMIT=false
# PHASE1_CONTACT_FORM=false

# --- Enricher (Phase E) — Overpass / OpenStreetMap (no API key required) ---
# Uses productConfig.osm.overpassUrl — results cached in Turso osm_cache table
