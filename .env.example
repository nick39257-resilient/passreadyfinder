# Turso database (required on Render)
# Create a free database at https://turso.tech
TURSO_DATABASE_URL=libsql://your-database-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# Optional: use a local SQLite file instead of remote Turso (local dev only — not used on Render/Vercel)
# TURSO_LOCAL_PATH=./data/leads.db

# Optional: local dev port (Render sets PORT automatically)
# REVIEW_PORT=3000
# REVIEW_HOST=localhost

# --- Drafter (Phase B) — LLM + WhatsApp trapdoor link ---
# Gemini OpenAI compatibility layer:
OPENAI_API_KEY=your-google-api-key-here
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# Drafting model only (QueueDrafter, quick_draft, npm run draft). See ai.google.dev/gemini-api/docs/models
# GEMINI_DRAFT_MODEL=gemini-3.1-flash-lite

# Draft review gating:
# - If true, every draft routes to Needs Eyes (/review) instead of auto-postboxing.
REVIEW_ALL_DRAFTS=false

# WhatsApp Business number (digits only, no +)
WHATSAPP_NUMBER=447000000000

# PassReady trial link (used after reply / follow-up flows)
TRIAL_URL=https://passready.uk

# --- Sender (Phase D) — Resend email delivery ---
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=PassReady <hello@your-sending-domain.com>
# Local testing only — never used in production unless ALLOW_TEST_EMAIL_FALLBACK=true
# TEST_EMAIL_ADDRESS=you@example.com
# ALLOW_TEST_EMAIL_FALLBACK=true

# --- Outreach limits & public links ---
# Max approved emails sent per UTC day (default 50 in product.config if unset)
# DAILY_SEND_CAP=30
# Public base URL for unsubscribe links in emails (required on Render for opt-out)
# PUBLIC_APP_URL=https://passreadyfinder.onrender.com

# --- Control panel security (recommended on Render) ---
# When set, job triggers require Authorization: Bearer <secret> header
# CONTROL_PANEL_SECRET=your-long-random-string

# --- Enricher (Phase E) — Overpass / OpenStreetMap (no API key required) ---
# Uses productConfig.osm.overpassUrl — results cached in Turso osm_cache table
